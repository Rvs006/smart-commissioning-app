# Copy this file to infra/.env and replace every CHANGE_ME placeholder before
# running `docker compose`. Compose reads .env from the directory containing
# docker-compose.yml. Never commit the real .env; none of the values below are
# usable secrets — compose refuses to start while placeholders are missing.

# --- Postgres ---------------------------------------------------------------
# Database name and role used by the api and worker. DATABASE_URL is assembled
# inside docker-compose.yml from these three values, so they only live here.
POSTGRES_DB=smart_commissioning
POSTGRES_USER=smart_commissioning
# Database password. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- Redis ------------------------------------------------------------------
# Password enforced via `redis-server --requirepass`. REDIS_URL is assembled
# inside docker-compose.yml from this value. Generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- API authentication -----------------------------------------------------
# Shared API key required by the backend when AUTH_MODE=api_key (the compose
# default). Clients send it with every /api request; the frontend prompts for
# it and stores it locally. Generate with: openssl rand -hex 32
API_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- Optional overrides (sane defaults in docker-compose.yml) ----------------
# Host port (loopback only) where nginx serves the frontend and /api proxy.
#FRONTEND_PORT=8080
# Host port (loopback only) for direct API access while debugging.
#API_PORT=8000
# Comma-separated browser origins allowed by CORS for direct cross-origin API
# access. Same-origin traffic through the nginx /api proxy never needs CORS.
#CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
