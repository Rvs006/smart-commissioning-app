POSTGRES_DB=smart_commissioning
POSTGRES_USER=smart_commissioning
POSTGRES_PASSWORD=smart_commissioning

REDIS_URL=redis://redis:6379/0
# API and worker share this database. When DATABASE_URL is unset (local dev
# outside compose), both default to the SQLite file
# backend/runtime/smart_commissioning.db.
DATABASE_URL=postgresql+psycopg://smart_commissioning:smart_commissioning@postgres:5432/smart_commissioning

OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=commissioning-evidence

API_PORT=8000
FRONTEND_PORT=5173

