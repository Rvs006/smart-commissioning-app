{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-commissioning.local/schemas/udmi-validation-export-v1.schema.json",
  "title": "UDMI validation evidence export v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema",
    "exported_at",
    "project_id",
    "site_id",
    "run",
    "result_summary",
    "issues",
    "evidence_limitations"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "schema": { "const": "docs/schemas/udmi-validation-export-v1.schema.json" },
    "exported_at": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string" },
    "site_id": { "type": "string" },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "job_type",
        "status",
        "stage",
        "progress_percent",
        "created_at",
        "updated_at",
        "partial",
        "error_message"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "job_type": { "const": "udmi_validation" },
        "status": { "enum": ["queued", "running", "succeeded", "failed", "cancelled"] },
        "stage": { "type": "string" },
        "progress_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "created_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "partial": { "type": "boolean" },
        "error_message": { "type": ["string", "null"] }
      }
    },
    "result_summary": {
      "type": "object",
      "properties": {
        "validation_summary_v1": { "$ref": "#/$defs/validationSummary" }
      },
      "additionalProperties": true
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "issue_type", "severity", "description"],
        "properties": {
          "issue_id": { "type": "string" },
          "asset_id": { "type": ["string", "null"] },
          "issue_type": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "evidence_limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "assetMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected", "observed", "not_observed", "with_issues", "successfully_validated"],
      "properties": {
        "expected": { "type": "integer", "minimum": 0 },
        "observed": { "type": "integer", "minimum": 0 },
        "not_observed": { "type": "integer", "minimum": 0 },
        "with_issues": { "type": "integer", "minimum": 0 },
        "successfully_validated": { "type": "integer", "minimum": 0 },
        "unexpected": { "type": "integer", "minimum": 0 }
      }
    },
    "assetMetricsV11": {
      "allOf": [
        { "$ref": "#/$defs/assetMetrics" },
        { "required": ["unexpected"] }
      ]
    },
    "payloadMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected", "received", "with_issues", "successfully_validated"],
      "properties": {
        "expected": { "type": "integer", "minimum": 0 },
        "received": { "type": "integer", "minimum": 0 },
        "not_received": { "type": "integer", "minimum": 0 },
        "with_issues": { "type": "integer", "minimum": 0 },
        "successfully_validated": { "type": "integer", "minimum": 0 }
      }
    },
    "payloadMetricsV11": {
      "allOf": [
        { "$ref": "#/$defs/payloadMetrics" },
        { "required": ["not_received"] }
      ]
    },
    "faultMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_formatting_issues",
        "missing_points",
        "point_naming_issues",
        "additional_points",
        "stale_or_cadence",
        "other_issues"
      ],
      "properties": {
        "payload_formatting_issues": { "type": "integer", "minimum": 0 },
        "missing_points": { "type": "integer", "minimum": 0 },
        "point_naming_issues": { "type": "integer", "minimum": 0 },
        "additional_points": { "type": "integer", "minimum": 0 },
        "stale_or_cadence": { "type": "integer", "minimum": 0 },
        "other_issues": { "type": "integer", "minimum": 0 }
      }
    },
    "issueMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocking", "warning"],
      "properties": {
        "blocking": { "type": "integer", "minimum": 0 },
        "warning": { "type": "integer", "minimum": 0 }
      }
    },
    "payloadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_type",
        "expected",
        "received",
        "has_issues",
        "blocking_issue_count",
        "successfully_validated",
        "topic",
        "received_at"
      ],
      "properties": {
        "payload_type": { "enum": ["state", "metadata", "pointset"] },
        "expected": { "type": "boolean" },
        "received": { "type": "boolean" },
        "has_issues": { "type": "boolean" },
        "blocking_issue_count": { "type": "integer", "minimum": 0 },
        "successfully_validated": { "type": "boolean" },
        "topic": { "type": ["string", "null"] },
        "received_at": { "type": ["string", "null"] }
      }
    },
    "assetResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "system",
        "observed",
        "expected_payloads",
        "received_payloads",
        "all_expected_payloads_received",
        "all_received_payloads_successfully_validated",
        "successfully_validated",
        "issue_count",
        "blocking_issue_count",
        "last_observed_at",
        "payload_results"
      ],
      "properties": {
        "asset_id": { "type": "string" },
        "system": { "type": "string", "minLength": 1 },
        "observed": { "type": "boolean" },
        "expected_payloads": { "type": "integer", "minimum": 0 },
        "received_payloads": { "type": "integer", "minimum": 0 },
        "all_expected_payloads_received": { "type": "boolean" },
        "all_received_payloads_successfully_validated": { "type": "boolean" },
        "successfully_validated": { "type": "boolean" },
        "issue_count": { "type": "integer", "minimum": 0 },
        "blocking_issue_count": { "type": "integer", "minimum": 0 },
        "last_observed_at": { "type": ["string", "null"] },
        "payload_results": { "type": "array", "items": { "$ref": "#/$defs/payloadResult" } }
      }
    },
    "faultRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "asset_id",
        "system",
        "payload_type",
        "category",
        "severity",
        "description",
        "point_name",
        "expected_value",
        "observed_value",
        "suggested_action",
        "raw_evidence_uri"
      ],
      "properties": {
        "issue_id": { "type": "string" },
        "asset_id": { "type": ["string", "null"] },
        "system": { "type": "string", "minLength": 1 },
        "payload_type": { "type": ["string", "null"] },
        "category": { "enum": ["payload_formatting_issues", "missing_points", "point_naming_issues", "additional_points", "stale_or_cadence", "other_issues"] },
        "severity": { "type": "string" },
        "description": { "type": "string" },
        "point_name": { "type": ["string", "null"] },
        "expected_value": { "type": ["string", "null"] },
        "observed_value": { "type": ["string", "null"] },
        "suggested_action": { "type": ["string", "null"] },
        "raw_evidence_uri": { "type": ["string", "null"] }
      }
    },
    "unexpectedDevice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "topic_root", "topics", "last_seen"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "topic_root": { "type": "string" },
        "topics": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "last_seen": { "type": ["string", "null"] }
      }
    },
    "systemMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "asset_metrics", "payload_metrics", "fault_metrics", "issue_metrics"],
      "properties": {
        "system": { "type": "string", "minLength": 1 },
        "asset_metrics": { "$ref": "#/$defs/assetMetrics" },
        "payload_metrics": { "$ref": "#/$defs/payloadMetrics" },
        "fault_metrics": { "$ref": "#/$defs/faultMetrics" },
        "issue_metrics": { "$ref": "#/$defs/issueMetrics" }
      }
    },
    "systemMetricV11": {
      "allOf": [
        { "$ref": "#/$defs/systemMetric" },
        {
          "properties": {
            "asset_metrics": { "$ref": "#/$defs/assetMetricsV11" },
            "payload_metrics": { "$ref": "#/$defs/payloadMetricsV11" }
          }
        }
      ]
    },
    "validationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "asset_metrics", "payload_metrics", "fault_metrics", "issue_metrics", "system_metrics", "asset_results", "fault_rows"],
      "properties": {
        "schema_version": { "enum": ["1.0", "1.1"] },
        "asset_metrics": { "$ref": "#/$defs/assetMetrics" },
        "payload_metrics": { "$ref": "#/$defs/payloadMetrics" },
        "fault_metrics": { "$ref": "#/$defs/faultMetrics" },
        "issue_metrics": { "$ref": "#/$defs/issueMetrics" },
        "system_metrics": { "type": "array", "items": { "$ref": "#/$defs/systemMetric" } },
        "asset_results": { "type": "array", "items": { "$ref": "#/$defs/assetResult" } },
        "fault_rows": { "type": "array", "items": { "$ref": "#/$defs/faultRow" } },
        "unexpected_devices": {
          "type": "array",
          "items": { "$ref": "#/$defs/unexpectedDevice" }
        },
        "unexpected_devices_measured": { "type": "boolean" },
        "unexpected_devices_measurement_scope": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "schema_version": { "const": "1.1" } },
            "required": ["schema_version"]
          },
          "then": {
            "required": [
              "unexpected_devices",
              "unexpected_devices_measured",
              "unexpected_devices_measurement_scope"
            ],
            "properties": {
              "asset_metrics": { "$ref": "#/$defs/assetMetricsV11" },
              "payload_metrics": { "$ref": "#/$defs/payloadMetricsV11" },
              "system_metrics": {
                "type": "array",
                "items": { "$ref": "#/$defs/systemMetricV11" }
              }
            }
          }
        }
      ]
    }
  }
}
